generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================
// 🏢 1. JEDWALI LA WAFANYABIASHARA (SaaS Tenants)
// ==================================================
model Business {
  id               String     @id @default(uuid())
  businessName     String
  fullName         String     
  
  // Imekuwa optional (String?) kuruhusu wanaosajili kwa Facebook
  phone            String?    @unique 
  password         String?    
  
  // 🔥 TAARIFA ZA FACEBOOK / META AUTH
  facebookId       String?    @unique 
  wabaId           String?    // WhatsApp Business Account ID
  
  // Taarifa za WhatsApp API kutoka Meta
  whatsappPhoneId  String?
  metaAccessToken  String?    
  walletBalance    Float      @default(0.0) 
  
  // Mahusiano
  contacts         Contact[]
  messages         Message[]
  campaigns        Campaign[]
  
  // Timestamps
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Indexes kwa utendaji wa haraka
  @@index([phone])
  @@index([facebookId])
  @@index([wabaId])
}

// ==================================================
// 👥 2. JEDWALI LA WATEJA (Contacts / Wanaopokea SMS)
// ==================================================
model Contact {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name        String?
  phoneNumber String    // Mfano: 255712345678 (Bila + )
  
  // Mahusiano
  messages    Message[]
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Tunazuia namba moja isijirudie kwa mfanyabiashara yule yule
  @@unique([businessId, phoneNumber])
  
  // 🔥 Index kwa kasi ya kutafuta wateja wa business fulani
  @@index([businessId])
}

// ==================================================
// 💬 3. JEDWALI LA MESEJI (Live Chat & SMS History)
// ==================================================
model Message {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // 🔥🔥🔥 HII NDIO SIRI YA UPSERT KUFANYA KAZI! 🔥🔥🔥
  // metaMsgId inatoka WhatsApp - inahakikisha hakuna duplicate messages
  metaMsgId   String?   @unique
  
  direction   String    // 'INBOUND' (Mteja katuma) au 'OUTBOUND' (Biashara imetuma)
  content     String    // Ujumbe wenyewe
  status      String    @default("SENT") // PENDING, SENT, DELIVERED, READ, FAILED, RECEIVED
  messageType String?   @default("text") // text, template, button, interactive, nk.
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 🔥 Index kwa ajili ya Live Chat na Dashboard Stats
  @@index([businessId, contactId])
  @@index([businessId, direction])
  @@index([businessId, status])
  @@index([metaMsgId])
}

// ==================================================
// 📊 4. JEDWALI LA KAMPENI ZA BULK SMS
// ==================================================
model Campaign {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  campaignName  String   // Mfano: "Ofa ya Sabasaba"
  templateName  String   // Jina la template ya Meta API
  templateLang  String   @default("sw") // Lugha ya template
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  totalContacts Int      @default(0)
  successCount  Int      @default(0) // Zilizotumwa kikamilifu
  failedCount   Int      @default(0) // Zilizofeli
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // 🔥 Index kwa ajili ya historia ya kampeni na dashboard
  @@index([businessId])
  @@index([businessId, status])
  @@index([createdAt])
}