generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================
// 🏢 1. JEDWALI LA WAFANYABIASHARA (SaaS Tenants)
// ==================================================
model Business {
  id               String     @id @default(uuid())
  businessName     String
  fullName         String     
  
  phone            String?    @unique
  password         String?
  
  // TAARIFA ZA FACEBOOK / META AUTH
  facebookId       String?    @unique
  wabaId           String?    
  whatsappPhoneId  String?
  metaAccessToken  String?   
  walletBalance    Float      @default(0.0) 
  
  // Mahusiano
  contacts         Contact[]
  messages         Message[]
  campaigns        Campaign[]
  
  // Timestamps (🔥 KINGA IMEONGEZWA HAPA)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt

  // Indexes kwa utendaji wa haraka
  @@index([phone])
  @@index([facebookId])
  @@index([wabaId])
}

// ==================================================
// 👥 2. JEDWALI LA WATEJA (Contacts / Wanaopokea SMS)
// ==================================================
model Contact {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name        String?
  phoneNumber String    
  
  // Mahusiano
  messages    Message[]
  
  // Timestamps (🔥 KINGA IMEONGEZWA HAPA KUZUIA NULL ERROR)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@unique([businessId, phoneNumber])
  @@index([businessId])
}

// ==================================================
// 💬 3. JEDWALI LA MESEJI (Live Chat & SMS History)
// ==================================================
model Message {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // metaMsgId inatoka WhatsApp - inahakikisha hakuna duplicate messages
  metaMsgId   String?   @unique
  
  direction   String    
  content     String    
  status      String    @default("SENT") 
  messageType String?   @default("text")
  
  // Timestamps (🔥 KINGA IMEONGEZWA HAPA)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@index([businessId, contactId])
  @@index([businessId, direction])
  @@index([businessId, status])
  @@index([metaMsgId])
}

// ==================================================
// 📊 4. JEDWALI LA KAMPENI ZA BULK SMS
// ==================================================
model Campaign {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  campaignName  String   
  templateName  String   
  templateLang  String   @default("sw") 
  status        String   @default("PENDING") 
  totalContacts Int      @default(0)
  successCount  Int      @default(0) 
  failedCount   Int      @default(0) 
  
  // Timestamps (🔥 KINGA IMEONGEZWA HAPA)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  
  @@index([businessId])
  @@index([businessId, status])
  @@index([createdAt])
}